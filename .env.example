# Скопируйте в файл `.env` в корне проекта и при необходимости измените.
# Результаты пайплайна по умолчанию: outputs/output.mp4 и outputs/report.txt (каталог outputs/ создаётся сам).
# Подробнее о шкале 1–7 и переменных см. README.md → раздел «Логирование (Loguru)».

# -----------------------------------------------------------------------------
# Уровни логирования (ровно 7 уровней по цифре)
# -----------------------------------------------------------------------------
# Задаются ЦИФРОЙ 1–7 (чем больше — тем подробнее) или именем Loguru.
#
# Кратко:
#   1 — только CRITICAL
#   2 — ERROR и выше
#   3 — WARNING и выше
#   4 — INFO и выше (значение по умолчанию, обычный режим)
#   5 — SUCCESS и выше (по шкале Loguru)
#   6 — DEBUG и выше
#   7 — TRACE: все уровни логов (максимум)
#
# Базовый уровень для консоли и файла, если ниже не переопределено:
LOG_LEVEL=4

# Только консоль (stderr). Пусто или закомментировано = использовать LOG_LEVEL.
# LOG_CONSOLE_LEVEL=7

# Только файлы в logs/detection_YYYY-MM-DD.log. Пусто = LOG_LEVEL.
# LOG_FILE_LEVEL=3
